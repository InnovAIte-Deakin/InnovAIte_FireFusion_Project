# Copy this file to .env and fill in real values.
# .env is gitignored at the repo root — never commit real values.

# ─── Existing infrastructure ──────────────────────────────────────────────
# Defaults match the local docker-compose at backend/docker-compose.yaml.
BROKER_URL=amqp://guest:guest@localhost:5672
CACHE_URL=redis://localhost:6379

# ─── Auth0 / JWT ──────────────────────────────────────────────────────────
# Auth0 tenant domain. e.g. firefusion-dev.au.auth0.com
# Find it: Auth0 dashboard → top-left tenant switcher
AUTH0_DOMAIN=

# The "Identifier" of the API resource you created inside Auth0.
# Example: https://api.firefusion.com
# Find it: Applications → APIs → (your API) → Settings → Identifier
AUTH0_AUDIENCE=

# URL prefix for custom claims (e.g. roles).
# Must match what the Post-Login Action sets in the Auth0 dashboard.
AUTH0_ROLE_NAMESPACE=https://firefusion.com/
