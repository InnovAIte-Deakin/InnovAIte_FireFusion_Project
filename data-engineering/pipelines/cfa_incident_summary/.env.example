# Supabase API (required for --load) — Dashboard → Settings → API
# Copy to .env and fill in real values. Never commit .env
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Optional: direct Postgres (psql only — NOT used by Python load scripts)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# Optional: override raw CFA file path (default: data/raw/cfa_incident_summary.xlsx)
# CFA_INCIDENT_RAW_PATH=F:\path\to\CFA_Incident_Summary.xlsx
